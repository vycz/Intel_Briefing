# ============================================================
#  .gitignore —— 公开仓库「收什么 / 不收什么」
#  规则：被本文件忽略的 = 私人/本地，永不上 GitHub
#        git 已跟踪的    = 公开，会上 GitHub
#  查某文件归属： git check-ignore <文件>   （有输出=私人）
#  完整速查地图： 见根目录 WORKSPACE_MAP.md（也不公开）
#  注意：gitignore 不支持行内注释，注释必须单独成行。
# ============================================================

# === 密钥与环境 ===
.env
.secrets/

# === 不收：本地运行产物 / 缓存 / 归档 ===
# 生成的日报（你的私有情报）
reports/
# 归档的旧杂物
.archive/
# pip install -e . 的产物
intel_briefing.egg-info/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.pytest_cache/
*.log

# === 不收：个人画像与商业策略 ===
# 你的个人画像（公开版只有 commander_state.example.md）
prompts/commander_state.md
AIA_Field_Manual.md
SKILL.md
# 玩家档案 / 任务系统 / 收入数据
player/
quests/
revenue/
.agent/skills/revenue-architect/prompts/

# === 不收：Agent / 工具的本地配置 ===
.agent/
.agents/
.antigravity/
.antigravitycli/
.claude/
.claude_ipc/
.gemini/
.gemini_ipc/
.obsidian/

# === 不收：内部文档与 AI 上下文 ===
# 本地 AI 上下文（含私有仓库名/安全债，勿公开）
GEMINI.md
# 同类 AI 上下文，预防性忽略（要公开请 git add -f）
CLAUDE.md
AGENTS.md
# 本地工作区速查地图
WORKSPACE_MAP.md
# 内部设计稿（要公开可 git add -f）
docs/decision_action_loop_design.md
docs/CODEX_*
docs/HANDOFF_*
docs/GEMINI_AUDIT_REPORT.md
docs/MEMORY_BANK_BLUEPRINT.md

# === 不收：社交 / 内容创作草稿 ===
claude_xhs_*
gemini_xhs_prompt.txt
article_content.txt
tweet.json

# === 不收：临时 / 调试 / 草稿数据 ===
tmp/
temp_*.csv
debug_*.py
*.bak
.mbignore
tmp_recurrence*.txt
scan_results.json
ppt_search.json
w*_summary.json
task.md
implementation_plan.md

# === 系统 / IDE ===
.DS_Store
Thumbs.db
.vscode/
.idea/
