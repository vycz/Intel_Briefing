# ===========================================
# Intel Briefing - 环境变量配置模板
# ===========================================
# 复制此文件为 .env 并填入你的 API Key

# GitHub Token (用于 GitHub Trending 等)
GITHUB_TOKEN=ghp_your_github_personal_access_token_here

# X/Grok API (用于 Twitter/X 舆情分析)
XAI_API_KEY=sk-your_grok_api_key_here
# ⚠️ 以下默认值对齐 .github/workflows/daily-report.yml
XAI_BASE_URL=https://openrouter.ai/api/v1/chat/completions
XAI_MODEL=x-ai/grok-4.3

# Product Hunt API (官方 API Token)
PRODUCTHUNT_TOKEN=your_producthunt_developer_token_here

# LLM Provider (用于中文翻译+摘要)
# 可选值: gemini / deepseek
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# ===========================================
# 可选配置
# ===========================================

# OpenAI API (如果使用 OpenAI 作为 LLM)
# OPENAI_API_KEY=sk-your_openai_key_here

# Gemini API (如果使用 Google Gemini)
# GEMINI_API_KEY=your_gemini_api_key_here
